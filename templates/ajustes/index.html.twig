{% extends 'base.html.twig' %}

{% block title %}Ajustes | Busway{% endblock %}

{% block body %}
<h1>Ajustes</h1>
<p style="opacity: 0.7;">Gestiona tu cuenta y preferencias de navegación.</p>

<article style="padding: 2rem;">
    <h2 style="margin-top: 0; margin-bottom: 1.5rem;">👤 Perfil de Usuario</h2>
    <div style="display: flex; gap: 1.5rem; align-items: center; margin-bottom: 1.5rem;">
        <div style="width: 64px; height: 64px; border-radius: 50%; background: var(--form-element-valid-border-color); display: flex; align-items: center; justify-content: center; color: white; font-weight: bold; font-size: 1.5rem;">U</div>
        <div>
            <strong style="display: block; font-size: 1.1rem;">Usuario Busway</strong>
            <small style="display: block; opacity: 0.7;">usuario@busway.es</small>
        </div>
        <button class="button" style="margin-left: auto;">Editar Perfil</button>
    </div>
</article>

<article style="padding: 2rem;">
    <h2 style="margin-top: 0; margin-bottom: 1.5rem;">⚙️ Preferencias del Sistema</h2>

    <div style="display: flex; justify-content: space-between; align-items: center; padding-bottom: 1rem; border-bottom: 1px solid #ddd;">
        <div>
            <strong>Notificaciones Push</strong>
            <small style="display: block; opacity: 0.7;">Recibir alertas de retrasos y cambios en tiempo real.</small>
        </div>
        <input type="checkbox" checked>
    </div>

    <div style="padding: 1rem 0; display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid #ddd;">
        <div>
            <strong>Idioma de la Interfaz</strong>
            <small style="display: block; opacity: 0.7;">Selecciona tu idioma preferido para el dashboard.</small>
        </div>
        <select>
            <option>Español (ES)</option>
            <option>English (UK)</option>
            <option>Français (FR)</option>
            <option>Deutsch (DE)</option>
        </select>
    </div>

    <div style="padding: 1rem 0; display: flex; justify-content: space-between; align-items: center;">
        <div>
            <strong>Unidades de Distancia</strong>
            <small style="display: block; opacity: 0.7;">Mostrar distancias en kilómetros o millas.</small>
        </div>
        <select>
            <option>Kilómetros (km)</option>
            <option>Millas (mi)</option>
        </select>
    </div>
</article>

<article style="padding: 2rem;">
    <h2 style="margin-top: 0; margin-bottom: 1.5rem;">🔒 Seguridad</h2>
    <div style="display: flex; gap: 1rem; flex-wrap: wrap;">
        <button class="button button-outline" style="color: #dc2626; border-color: #dc2626;">Cambiar Contraseña</button>
        <button class="button button-outline">Cerrar Sesión en otros dispositivos</button>
    </div>
</article>
{% endblock %}
