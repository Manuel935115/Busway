{% extends 'base.html.twig' %}

{% block title %}Notificaciones — Busway{% endblock %}

{% block body %}
<h1>
    Notificaciones
    {% if total > 0 %}
        <span class="badge">{{ total }}</span>
    {% endif %}
</h1>

{% if total == 0 %}
    <article class="text-center" style="padding: 3rem 1rem;">
        <p style="opacity: 0.7; font-size: 1.1rem;">Sin retrasos en tus búsquedas</p>
    </article>
{% else %}
    {% if trenes|length > 0 %}
        <h2 style="margin-top: 2rem; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.5px; opacity: 0.6;">Trenes</h2>
        {% for t in trenes %}
            {% set delayClass = t.retraso > 30 ? 'badge-red' : (t.retraso > 15 ? 'badge-orange' : 'badge-green') %}
            <article style="display: flex; align-items: center; gap: 1rem; padding: 1rem;">
                <div>
                    {% set tipo = t.tipo|upper|default('') %}
                    {% if 'OUIGO' in tipo %}
                        <img src="{{ app.request.getBasePath() }}/images/operators/ouigo.png" alt="Ouigo" style="width: 42px; height: 42px; object-fit: contain;">
                    {% elseif 'IRYO' in tipo or 'FRECC' in tipo %}
                        <img src="{{ app.request.getBasePath() }}/images/operators/iryo.png" alt="Iryo" style="width: 42px; height: 42px; object-fit: contain;">
                    {% elseif 'AVLO' in tipo %}
                        <img src="{{ app.request.getBasePath() }}/images/operators/avlo.png" alt="Avlo" style="width: 42px; height: 42px; object-fit: contain;">
                    {% elseif 'AVE' in tipo and 'ALVIA' not in tipo %}
                        <img src="{{ app.request.getBasePath() }}/images/operators/ave.png" alt="AVE" style="width: 42px; height: 42px; object-fit: contain;">
                    {% elseif 'ALVIA' in tipo %}
                        <img src="{{ app.request.getBasePath() }}/images/operators/alvia.png" alt="Alvia" style="width: 42px; height: 42px; object-fit: contain;">
                    {% elseif 'CERCAN' in tipo or 'RODAL' in tipo %}
                        <img src="{{ app.request.getBasePath() }}/images/operators/cercanias.png" alt="Cercanías" style="width: 42px; height: 42px; object-fit: contain;">
                    {% else %}
                        <img src="{{ app.request.getBasePath() }}/images/operators/renfe.png" alt="Renfe" style="width: 42px; height: 42px; object-fit: contain;">
                    {% endif %}
                </div>
                <div style="flex: 1;">
                    <strong>{{ t.tipo ?? 'Tren' }} {{ t.codigo }}</strong>
                    <small style="display: block; opacity: 0.7;">{{ t.origen ?? '—' }} → {{ t.destino ?? '—' }}</small>
                </div>
                <span class="badge {{ delayClass }}">+{{ t.retraso }} min</span>
                <small style="opacity: 0.6; white-space: nowrap;">{{ t.actualizado }}</small>
            </article>
        {% endfor %}
    {% endif %}

    {% if vuelos|length > 0 %}
        <h2 style="margin-top: 2rem; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.5px; opacity: 0.6;">Vuelos</h2>
        {% for v in vuelos %}
            {% set delayClass = v.retraso > 60 ? 'badge-red' : (v.retraso > 30 ? 'badge-orange' : 'badge-green') %}
            <article style="display: flex; align-items: center; gap: 1rem; padding: 1rem;">
                <div style="width: 42px; height: 42px; display: flex; align-items: center; justify-content: center; background: rgba(234,88,12,0.1); border-radius: 8px; color: #ea580c;">
                    ✈
                </div>
                <div style="flex: 1;">
                    <strong>Vuelo {{ v.numero }}</strong>
                    <small style="display: block; opacity: 0.7;">{{ v.estado ?? '—' }}</small>
                </div>
                <span class="badge {{ delayClass }}">+{{ v.retraso }} min</span>
                <small style="opacity: 0.6; white-space: nowrap;">{{ v.actualizado }}</small>
            </article>
        {% endfor %}
    {% endif %}
{% endif %}
{% endblock %}
