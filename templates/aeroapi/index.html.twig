function toggleExpand(expandId, row) {
    const expand = document.getElementById(expandId);
    if (!expand) return;
    const open = expand.style.display !== 'none';
    expand.style.display = open ? 'none' : 'table-row';
    const chevron = row.querySelector('.row-chevron');
    if (chevron) chevron.style.transform = open ? '' : 'rotate(90deg)';
