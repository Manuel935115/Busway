// Datos para el mapa
let currentFlightData = null;

// Mapas en filas de servicios (bus/tren)
const svcMaps = {};

async function toggleSvcMap(expandId) {
    const inner = document.getElementById('map-inner-' + expandId);
    const chev  = document.getElementById('map-chev-' + expandId);
    const row   = document.getElementById(expandId);

    if (!inner || !row) return;

    const isOpen = inner.style.display === 'block';
    if (isOpen) {
        inner.style.display = 'none';
        chev.style.transform = 'rotate(0deg)';
        return;
    }

    inner.style.display = 'block';
    chev.style.transform = 'rotate(180deg)';

    // Solo inicializar el mapa una vez
    if (svcMaps[expandId]) return;

    const coordRaw = row.dataset.coord || '';
    if (!coordRaw) return;

    let coords;
    try { coords = JSON.parse(coordRaw); } catch(e) { return; }

    const start = coords.start;
    const end   = coords.end;
    if (!start || !end) return;

    const mapEl = document.getElementById('map-el-' + expandId);
    const infoEl = document.getElementById('map-info-' + expandId);

    // Inicializar mapa Leaflet
    const map = L.map(mapEl, { zoomControl: false, attributionControl: false });
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png').addTo(map);
    svcMaps[expandId] = map;

    // Marcadores
    const iconBlue  = L.divIcon({ className:'', html:'<div style="width:12px;height:12px;background:#4361ee;border:2px solid #fff;border-radius:50%;box-shadow:0 1px 4px rgba(0,0,0,0.3);"></div>', iconAnchor:[6,6] });
    const iconGreen = L.divIcon({ className:'', html:'<div style="width:12px;height:12px;background:#16a34a;border:2px solid #fff;border-radius:50%;box-shadow:0 1px 4px rgba(0,0,0,0.3);"></div>', iconAnchor:[6,6] });
    L.marker([start.lat, start.lng], { icon: iconBlue  }).addTo(map);
    L.marker([end.lat,   end.lng  ], { icon: iconGreen }).addTo(map);

    // Ajustar vista a los dos puntos
    const bounds = L.latLngBounds([[start.lat, start.lng], [end.lat, end.lng]]);
    map.fitBounds(bounds, { padding: [30, 30] });

    // Click en mapa → Google Maps
    const gmapsUrl = `https://www.google.com/maps/dir/${start.lat},${start.lng}/${end.lat},${end.lng}`;
    mapEl.addEventListener('click', () => window.open(gmapsUrl, '_blank'));

    // Ruta y duración desde OSRM (gratis, sin API key)
    try {
        const osrm = await fetch(`https://router.project-osrm.org/route/v1/driving/${start.lng},${start.lat};${end.lng},${end.lat}?overview=full&geometries=geojson`);
        const data = await osrm.json();
        const route = data.routes?.[0];
        if (route) {
            // Dibujar ruta en el mapa
            L.geoJSON(route.geometry, { style: { color:'#4361ee', weight:4, opacity:0.8 } }).addTo(map);

            // Mostrar duración y distancia
            const mins = Math.round(route.duration / 60);
            const km   = (route.distance / 1000).toFixed(1);
            const h    = Math.floor(mins / 60);
            const m    = mins % 60;
            const durStr = h > 0 ? `${h}h ${m}min` : `${m} min`;
            infoEl.innerHTML = `🚗 ${km} km · ⏱ ${durStr} &nbsp;·&nbsp; <a href="${gmapsUrl}" target="_blank" style="color:var(--accent);font-weight:700;text-decoration:none;">Abrir en Google Maps →</a>`;
        }
    } catch(e) {
        infoEl.innerHTML = `<a href="${gmapsUrl}" target="_blank" style="color:var(--accent);font-weight:700;text-decoration:none;">Abrir en Google Maps →</a>`;
    }

    // Refrescar mapa tras animar
    setTimeout(() => map.invalidateSize(), 310);
}
</script>
{% endblock %}
