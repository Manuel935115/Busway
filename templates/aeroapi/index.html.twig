// Cache y optimización API
const busApiCache = new Map();
let busAbortController = null;
let busDebounceTimer = null;

function getCacheKey(q) { return 'bus_' + q.toLowerCase(); }
function getCachedBus(key) {
    const stored = localStorage.getItem(key);
    if (!stored) return null;
    try { const obj = JSON.parse(stored); return obj.exp > Date.now() ? obj.data : null; }
    catch(e) { return null; }
}
function setCacheBus(key, data) { localStorage.setItem(key, JSON.stringify({data, exp: Date.now() + 900000})); }

async function cargarBusLive(expandId, origenRaw) {
    const container = document.getElementById('bus-live-' + expandId);
    if (!container || container.dataset.loaded) return;
    container.dataset.loaded = '1';

    const q = origenRaw.replace(/\s*\(.*?\)/g, '').trim();
    if (q.length < 2) { container.innerHTML = '<div class="bus-live-msg">No hay datos disponibles.</div>'; return; }

    if (busAbortController) busAbortController.abort();
    busAbortController = new AbortController();
    const signal = busAbortController.signal;

    try {
        const stopsCacheKey = getCacheKey(q);
        let stops = getCachedBus(stopsCacheKey);

        if (!stops) {
            const r = await fetch('/api/buses/autocompletear?q=' + encodeURIComponent(q), {signal});
            stops = await r.json();
            if (stops.length) setCacheBus(stopsCacheKey, stops);
        }

        if (!stops.length) { container.innerHTML = '<div class="bus-live-msg">Parada no encontrada.</div>'; return; }

        const stop = stops[0];
        const parCacheKey = 'buspar_' + stop.id;
        let data = getCachedBus(parCacheKey);

        if (!data) {
            const r = await fetch('/api/buses/parada/' + stop.id, {signal});
            data = await r.json();
            if (!data.error) setCacheBus(parCacheKey, data);
        }

        if (data.error) { container.innerHTML = '<div class="bus-live-msg">⚠ ' + data.error + '</div>'; return; }

        const arrivals = data.arrivals || [];
        const stopName = data.stopInfo ? (data.stopInfo.stopName || stop.name) : stop.name;
        let html = '<div class="bus-live-title">Bus tiempo real</div>'
            + '<div class="bus-live-stop"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="2.5"><rect x="3" y="3" width="18" height="18" rx="3"/><path d="M3 9h18M3 15h18M9 9v6M15 9v6"/></svg>' + stopName + '</div>';

        if (!arrivals.length) {
            html += '<div class="bus-live-msg">Sin próximas llegadas.</div>';
        } else {
            arrivals.slice(0, 5).forEach(a => {
                const mins = Math.round((a.busTimeLeft || a.estimateArrive || 0) / 60);
                const timeClass = mins <= 3 ? 'bus-live-time soon' : 'bus-live-time';
                const timeText = mins <= 0 ? 'Llegando' : mins + ' min';
                const dest = (a.destinationName || a.destination || '—').substring(0, 18);
                const line = a.lineId || a.line || '?';
                html += '<div class="bus-live-row">'
                    + '<div class="bus-live-line">' + line + '</div>'
                    + '<div class="bus-live-dest">' + dest + '</div>'
                    + '<div class="' + timeClass + '">' + timeText + '</div>'
                    + '</div>';
            });
        }
        container.innerHTML = html;
    } catch(e) {
        if (e.name !== 'AbortError') container.innerHTML = '<div class="bus-live-msg">⚠ Error API buses.</div>';
    }
}

// Prefetch top 3 vuelos y limpiar caché expirado al cargar
document.addEventListener('DOMContentLoaded', () => {
    const rows = document.querySelectorAll('.srv-table tbody tr:not(.expand-row):not(.tren-row):not(.bus-row)');
    rows.forEach((row, idx) => {
        if (idx < 3) {
            const onclick = row.getAttribute('onclick');
            if (onclick && onclick.includes('abrirVuelo')) {
                setTimeout(() => {
                    try {
                        const match = onclick.match(/abrirVuelo\(({.*?}),/);
                        if (match) {
                            const data = JSON.parse(match[1]);
                            fetch('{{ path('api_vuelo_info', {'flight': 'X'}) }}'.replace('X', encodeURIComponent(data.vueloTren)));
                        }
                    } catch(e) {}
                }, 200 + idx * 100);
            }
        }
    });

    // Limpiar localStorage expirado
    for (let key in localStorage) {
        try {
            const obj = JSON.parse(localStorage.getItem(key));
            if (obj.exp && obj.exp <= Date.now()) localStorage.removeItem(key);
        } catch(e) {}
    }
});

// Infinite scroll — carga 20 servicios más desde la API al llegar abajo
(function() {
    let srvOffset = {{ servicios|length }};
    let srvLoading = false;
    let srvDone = false;
    const sentinel = document.getElementById('scroll-sentinel');
    const sentinelText = document.getElementById('sentinel-text');
    const tbody = document.querySelector('.srv-table tbody');
    if (!sentinel || !tbody) return;

    // Si la carga inicial trajo menos de 20, ya no hay más
    if (srvOffset < 20) {
        sentinelText.textContent = 'No hay más vuelos';
        sentinelText.style.opacity = '0.6';
        return;
    }

    function buildRow(s, idx) {
        const vt = (s.vt || '').toLowerCase();
        const esBus = vt.includes('movelia') || vt.includes('bus') || /^(sr|br|fr|alsa|blablacar)/.test(vt);
        const esTren = !esBus && (/^(alvia|avlo|iryo|euromed|avant|cercanias|nm|md|i6|rd)/.test(vt) || vt.slice(0,2)==='md' || vt.slice(0,2)==='i6');
        const rowId = 'row-dyn-' + srvOffset + '-' + idx;
        const expandId = 'expand-dyn-' + srvOffset + '-' + idx;
        const codigo = s.co || '';
        const vueloTren = s.vt || '';
        const origen = s.or || '';
        const destino = s.de || '';
        const fecha = s.fe || '';
        const pax = s.pa || '0';
        const fechaParts = fecha.split(' ');
        const origenShort = origen.split(' ')[0];
        const destinoShort = destino.split(' ')[0];

        let rowClass = 'srv-data-row';
        let onclick = '';
        let chevron = '';
        let logo = '';
        let nameSpan = '';
        let route = '';

        if (esBus) {
            rowClass += ' expand-row bus-row';
            onclick = `onclick="toggleExpand('${expandId}', this)"`;
            chevron = '<svg class="row-chevron" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="2.5" style="transition:transform 0.2s; display:block; margin:auto;"><path d="M9 6l6 6-6 6"/></svg>';
            logo = '<div class="airline-logo-wrap" style="background:rgba(22,163,74,0.08);border-color:rgba(22,163,74,0.25);"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="3"/><path d="M3 9h18M3 15h18M9 9v6M15 9v6"/></svg></div>';
            nameSpan = `<span class="flight-num" style="color:#16a34a; font-size:0.82rem;">${vueloTren}</span>`;
            route = `<div style="font-size:0.82rem; font-weight:600; color:var(--text-muted);">${origenShort} → ${destinoShort}</div>`;
        } else if (esTren) {
            rowClass += ' expand-row tren-row';
            onclick = `onclick="toggleExpand('${expandId}', this)"`;
            chevron = '<svg class="row-chevron" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#d97706" stroke-width="2.5" style="transition:transform 0.2s; display:block; margin:auto;"><path d="M9 6l6 6-6 6"/></svg>';
            logo = '<div class="airline-logo-wrap" style="background:rgba(217,119,6,0.08);border-color:rgba(217,119,6,0.25);"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#d97706" stroke-width="2"><rect x="4" y="3" width="16" height="16" rx="2"/><path d="M4 11h16M12 3v8M8 19l-2 3M18 22l-2-3M8 15h.01M16 15h.01"/></svg></div>';
            nameSpan = `<span class="flight-num" style="color:#d97706; font-size:0.75rem;">${vueloTren}</span>`;
            route = `<div style="font-size:0.82rem; font-weight:600; color:var(--text-muted);">${origenShort} → ${destinoShort}</div>`;
        } else {
            const srvData = JSON.stringify({codigo, origen, destino, pasajeros: pax, fecha, vueloTren}).replace(/"/g, '&quot;');
            onclick = `onclick="abrirVuelo(${srvData}, '${rowId}')"`;
            const iata = vueloTren.slice(0,2);
            const icao = vueloTren.slice(0,3);
            logo = `<div class="airline-logo-wrap"><img src="https://pics.avs.io/200/200/${iata}@2x.png" data-icao="${icao}" data-iata="${iata}" onload="this.style.opacity=1" onerror="logoFallback(this)" style="width:32px;height:32px;object-fit:contain;opacity:0;transition:opacity 0.2s;" alt=""></div>`;
            nameSpan = `<span class="flight-num">${vueloTren}</span>`;
            route = `<div class="route-cell"><div class="route-main"><span class="route-iata">${origenShort}</span><span class="route-arrow"><svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" style="transform:rotate(90deg);"><path d="M21 16v-2l-8-5V3.5A1.5 1.5 0 0 0 11.5 2 1.5 1.5 0 0 0 10 3.5V9l-8 5v2l8-2.5V19l-2 1.5V22l3.5-1 3.5 1v-1.5L13 19v-5.5z"/></svg></span><span class="route-iata">${destinoShort}</span></div><div class="route-sub">${origen} → ${destino}</div></div>`;
        }

        let fechaHtml = '—';
        if (fecha) {
            fechaHtml = `<div style="white-space:nowrap; line-height:1.5;"><div style="font-size:0.82rem; font-weight:600;">${fechaParts[0]}</div>${fechaParts[1] ? `<div style="font-size:0.75rem; color:var(--text-muted); font-weight:500;">${fechaParts[1]}</div>` : ''}</div>`;
        }

        let html = `<tr id="${rowId}" class="${rowClass}" data-ident="${codigo.toUpperCase()}" data-vuelo="${vueloTren.toUpperCase()}" data-fecha="${fechaParts[0]}" data-datetime="${fecha}" data-pax="${pax}" ${onclick}>
            <td style="text-align:center; padding:14px 8px;">${chevron}</td>
            <td><span class="code-badge">${codigo}</span></td>
            <td><div style="display:flex;align-items:center;gap:10px;min-width:0;">${logo}${nameSpan}</div></td>
            <td>${route}</td>
            <td style="font-size:0.82rem; font-weight:600; color:var(--text-primary); text-align:center; padding:12px 16px;">${fechaHtml}</td>
            <td style="text-align:center;"><span class="pax-badge"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="color:var(--text-muted)"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg> ${pax}</span></td>
        </tr>`;

        if (esBus || esTren) {
            const cls = esBus ? 'svc-bus' : 'svc-tren';
            const btnCls = esBus ? 'svc-btn-bus' : 'svc-btn-tren';
            const btnHref = esBus ? '{{ path('app_buses') }}' : '{{ path('app_trenes') }}';
            const btnText = esBus ? 'Ver más en Rastrear Bus' : 'Ver trenes';
            const coord = s.cd || '';
            html += `<tr id="${expandId}" style="display:none;" ${coord ? `data-coord="${coord.replace(/"/g,'&quot;')}"` : ''} ${esBus ? `data-origen="${origen.replace(/"/g,'&quot;')}"` : ''}>
                <td colspan="6" style="padding:0;">
                    <div class="svc-expand-body ${cls}">
                        <div class="svc-expand-grid">
                            <div class="svc-expand-item"><div class="svc-expand-label">Recogida</div><div class="svc-expand-value">${fecha}</div></div>
                            <div class="svc-expand-item"><div class="svc-expand-label">Pasajeros</div><div class="svc-expand-value">${pax} pax</div></div>
                            <div class="svc-expand-item" style="grid-column:span 2;"><div class="svc-expand-label">Origen</div><div class="svc-expand-value">${origen}</div></div>
                            <div class="svc-expand-item" style="grid-column:span 2;"><div class="svc-expand-label">Destino</div><div class="svc-expand-value">${destino}</div></div>
                        </div>
                        <a href="${btnHref}" class="svc-expand-btn ${btnCls}">${btnText}</a>
                    </div>
                </td>
            </tr>`;
        }
        return html;
    }

    function loadMoreServicios() {
        if (srvLoading || srvDone) return;
        srvLoading = true;
        sentinelText.textContent = 'Cargando más…';
        sentinelText.style.opacity = '1';

        fetch('{{ path('api_servicios') }}?offset=' + srvOffset + '&limit=20')
            .then(r => r.json())
            .then(data => {
                const items = data.s || [];
                if (items.length === 0) {
                    srvDone = true;
                    sentinelText.textContent = 'No hay más vuelos';
                    sentinelText.style.opacity = '0.6';
                    scrollObs.disconnect();
                } else {
                    items.forEach((s, i) => {
                        tbody.insertAdjacentHTML('beforeend', buildRow(s, i));
                    });
                    srvOffset += items.length;
                    if (items.length < 20) {
                        srvDone = true;
                        sentinelText.textContent = 'No hay más vuelos';
                        sentinelText.style.opacity = '0.6';
                        scrollObs.disconnect();
                    }
                }
                srvLoading = false;
            })
            .catch(() => {
                srvLoading = false;
                sentinelText.textContent = 'Error al cargar';
            });
    }

    const scrollObs = new IntersectionObserver(entries => {
        if (entries[0].isIntersecting) loadMoreServicios();
    }, { rootMargin: '300px' });
    scrollObs.observe(sentinel);
})();

