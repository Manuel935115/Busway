{% extends 'base.html.twig' %}

{% block title %}Historial de Búsquedas | Busway{% endblock %}

{% block stylesheets %}
<style>
.header{margin-bottom:24px;display:flex;justify-content:space-between;align-items:flex-end}.header h1{font-size:1.6rem;font-weight:800;color:var(--text-primary);letter-spacing:-0.5px}.header p{margin:4px 0 0;color:var(--text-muted);font-size:0.85rem;font-weight:500}.header-count{color:var(--text-muted);font-size:0.82rem;font-weight:600;background:var(--card-bg);padding:6px 14px;border-radius:10px;box-shadow:0 1px 3px rgba(0,0,0,.06);border:1px solid var(--border)}.card{background:var(--card-bg);border-radius:20px;box-shadow:0 1px 3px rgba(0,0,0,.04),0 12px 40px rgba(0,0,0,.06);border:1px solid var(--border);overflow:hidden}table{width:100%;border-collapse:collapse;text-align:left}th{background:rgba(0,0,0,.02);padding:14px 20px;font-size:.68rem;font-weight:700;color:var(--text-muted);text-transform:uppercase;letter-spacing:1px;border-bottom:1px solid var(--border)}body.dark-mode th{background:rgba(255,255,255,.03)}td{padding:16px 20px;border-top:1px solid var(--border);font-size:.88rem;color:var(--text-primary);vertical-align:middle}tbody tr:hover{background:rgba(0,0,0,.02)}body.dark-mode tbody tr:hover{background:rgba(255,255,255,.03)}.flight-num{font-weight:800;color:var(--text-primary);display:inline-flex;align-items:center;gap:8px}.flight-num svg{color:#4361ee;width:16px;height:16px}.route{display:flex;align-items:center;gap:8px;font-weight:700;color:var(--text-primary);font-size:.85rem}.route-arrow{color:var(--text-muted);font-weight:400;font-size:.9rem}.status{display:inline-block;padding:4px 12px;border-radius:8px;font-size:.65rem;font-weight:800;text-transform:uppercase;letter-spacing:.8px}.status.en-route{background:#4361ee;color:#fff}.status.arrived{background:#16a34a;color:#fff}.status.scheduled{background:#d97706;color:#fff}.date{color:var(--text-muted);font-size:.82rem;font-weight:500}.airline-logo{width:48px;height:48px;border-radius:10px;background:var(--card-bg);border:1px solid var(--border);display:flex;align-items:center;justify-content:center;overflow:hidden}.airline-logo img{width:40px;height:40px;object-fit:contain}tbody tr{cursor:pointer}.empty{padding:60px 24px;text-align:center;color:#94a3b8}.empty svg{margin-bottom:12px}.empty h3{color:var(--text-primary);font-size:1rem;font-weight:700;margin-bottom:6px}.empty p{color:var(--text-muted);font-size:.85rem;font-weight:500}.alert{padding:12px 20px;border-radius:12px;margin-bottom:20px;font-size:.85rem;font-weight:600}.alert-success{background:#dcfce7;color:#166534;border:1px solid #bbf7d0}#infinite-scroll-trigger{height:100px;text-align:center;padding:20px;color:var(--text-muted)}#loading-indicator{display:none}@keyframes spin{from{transform:rotate(0deg)}to{transform:rotate(360deg)}}#loading-indicator svg{animation:spin 1s linear infinite}.panel-overlay{position:fixed;inset:0;background:rgba(15,23,42,.45);backdrop-filter:blur(4px);z-index:200;opacity:0;visibility:hidden;transition:all .3s ease}.panel-overlay.open{opacity:1;visibility:visible}.detail-panel{position:fixed;top:0;right:0;bottom:0;width:420px;max-width:100vw;background:var(--card-bg);border-left:1px solid var(--border);z-index:201;display:flex;flex-direction:column;transform:translateX(100%);transition:transform .35s cubic-bezier(.4,0,.2,1);overflow-y:auto}.detail-panel.open{transform:translateX(0)}.panel-header{display:flex;align-items:center;gap:14px;padding:20px 22px;border-bottom:1px solid var(--border);position:sticky;top:0;background:var(--card-bg);z-index:1}.panel-logo{width:48px;height:48px;border-radius:10px;background:var(--card-bg);border:1px solid var(--border);display:flex;align-items:center;justify-content:center;overflow:hidden;flex-shrink:0}.panel-logo img{width:40px;height:40px;object-fit:contain}.panel-flight-num{font-size:1.3rem;font-weight:800;color:var(--text-primary);letter-spacing:-0.5px}.panel-operator{font-size:.8rem;color:var(--text-muted);font-weight:500;margin-top:2px}.panel-close{margin-left:auto;background:0;border:0;color:var(--text-muted);cursor:pointer;padding:6px;border-radius:8px;transition:background .15s}.panel-close:hover{background:rgba(0,0,0,.06)}.panel-body{padding:20px 22px;flex:1}.panel-status-row{margin-bottom:20px}.panel-route{display:flex;align-items:center;gap:10px;margin-bottom:22px}.panel-ep{flex:1}.panel-ep-code{font-size:1.5rem;font-weight:900;color:var(--text-primary);letter-spacing:-1px}.panel-ep-name{font-size:.75rem;color:var(--text-muted);font-weight:500;margin-top:2px}.panel-route-line{flex:1;height:2px;background:var(--border);position:relative}.panel-route-line::after{content:'✈';position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);font-size:16px;color:var(--accent);background:var(--card-bg);padding:0 6px}.panel-arrow{color:var(--text-muted)}.panel-section-title{font-size:.65rem;font-weight:800;text-transform:uppercase;letter-spacing:1.2px;color:var(--text-muted);margin:18px 0 10px}.panel-times{display:grid;grid-template-columns:1fr 1fr;gap:10px}.panel-time-item{background:rgba(0,0,0,.03);border:1px solid var(--border);border-radius:12px;padding:12px 14px}.body.dark-mode .panel-time-item{background:rgba(255,255,255,.04)}.panel-time-label{font-size:.65rem;color:var(--text-muted);font-weight:700;text-transform:uppercase;letter-spacing:.8px}.panel-time-val{font-size:.9rem;font-weight:700;color:var(--text-primary);margin-top:4px}.panel-time-val.delayed{color:#dc2626}.panel-time-val.ontime{color:#16a34a}.panel-info-row{display:flex;justify-content:space-between;align-items:center;padding:10px 0;border-bottom:1px solid var(--border);font-size:.84rem}.panel-info-row:last-child{border-bottom:0}.panel-info-label{color:var(--text-muted);font-weight:500}.panel-info-val{font-weight:700;color:var(--text-primary);text-align:right;max-width:60%}.panel-progress-wrap{margin:14px 0}.panel-progress-bar{height:6px;background:var(--border);border-radius:999px;overflow:hidden}.panel-progress-fill{height:100%;background:linear-gradient(90deg,var(--accent),#22c55e);border-radius:999px;transition:width .4s ease}.panel-progress-label{display:flex;justify-content:space-between;font-size:.72rem;color:var(--text-muted);margin-top:5px;font-weight:500}@media (max-width:768px){.header{flex-direction:column;gap:12px;align-items:flex-start}th,td{padding:12px 14px;font-size:.78rem}}@media (max-width:480px){.detail-panel{width:100vw}}
</style>
{% endblock %}

{% block body %}

<div class="content-wrap">
    <div class="header">
        <div>
            <h1>Historial de Búsquedas</h1>
            <p>Registro de todas las consultas realizadas en la base de datos.</p>
        </div>
    </div>

    {% for message in app.flashes('success') %}
        <div class="alert alert-success">
            {{ message }}
        </div>
    {% endfor %}

    <div class="card">
        {% if records|length > 0 %}
            <table id="flightsTable">
                <thead>
                    <tr><th>Aerolínea</th><th>Vuelo</th><th>Ruta</th><th>Fecha de Salida</th><th>Estado Guardado</th><th>Fecha de Búsqueda</th></tr>
                </thead>
                <tbody id="flightsTableBody">
                    {% for r in records %}{% set sc=r.estado.nombre %}{% if 'En Route' in sc or 'Taxi' in sc %}{% set sc='en-route' %}{% elseif 'Arrived' in sc %}{% set sc='arrived' %}{% elseif 'Scheduled' in sc %}{% set sc='scheduled' %}{% endif %}<tr onclick="abrirPanel({{ r.rawData|json_encode|e('html_attr') }},'{{ r.vuelo.numero }}')"><td><div class="airline-logo">{% set io=r.rawData.operator_icao|default(r.rawData.operator|default(r.vuelo.numero|slice(0,3)|upper)) %}<img loading="lazy" src="/images/airlines/{{ io }}.png" alt="{{ io }}" onerror="try{if(!this.dataset.step){this.dataset.step='1';this.src='https://e1.flightcdn.com/images/airline_logos/90p/{{ io|slice(0,3) }}.png';}else if(this.dataset.step==='1'){this.dataset.step='2';this.src='https://content.airhex.com/content/logos/airlines_{{ r.rawData.operator_iata|default('') }}_100_100_s.png';}else if(this.dataset.step==='2'){this.dataset.step='3';this.src='https://pics.avs.io/ab_icons/150/{{ io }}.png';}else{const l='{{ r.vuelo.numero }}'.charAt(0);this.parentElement.innerHTML='<div style=\"width:32px;height:32px;border-radius:8px;background:'+(window.c?.[l.charCodeAt(0)%8]||'#4361ee')+';color:white;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:1rem;\">'+l+'</div>';}}catch(e){}"></div><td><span class="flight-num">{{ r.vuelo.numero }}</span><td><div class="route">{{ r.rawData.origin.code_iata|default(r.rawData.origin.code|default('—')) }}<span class="route-arrow">→</span>{{ r.rawData.destination.code_iata|default(r.rawData.destination.code|default('—')) }}</div><td><span class="date tz-datetime" data-time="{{ r.horaSalida ? r.horaSalida|date('c') : '' }}">{{ r.horaSalida ? r.horaSalida|date('d/m/Y H:i') : '—' }}</span><td><span class="status {{ sc }}">{{ r.estado.nombre|default('—') }}</span><td><span class="date tz-datetime" data-time="{{ r.fechaHora|date('c') }}">{{ r.fechaHora|date('d/m/Y H:i:s') }}</span>{% endfor %}
                </tbody>
            </table>
            <div id="infinite-scroll-trigger">
                <div id="loading-indicator">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2" stroke-linecap="round"/></svg>
                    Cargando...
                </div>
            </div>
        {% else %}
            <div class="empty">
                <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 12h-4l-3 9L9 3l-3 9H2"></path></svg>
                <h3>No hay historial todavía</h3>
                <p>Busca un vuelo por primera vez para empezar a registrar en la base de datos.</p>
            </div>
        {% endif %}
    </div>
</div>

<div class="panel-overlay" id="panelOverlay" onclick="cerrarPanel()"></div>
<div class="detail-panel" id="detailPanel">
    <div class="panel-header">
        <div class="panel-logo" id="panelLogo"></div>
        <div>
            <div class="panel-flight-num" id="panelFlightNum"></div>
            <div class="panel-operator" id="panelOperator"></div>
        </div>
        <button class="panel-close" onclick="cerrarPanel()">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M18 6 6 18M6 6l12 12"/></svg>
        </button>
    </div>
    <div class="panel-body">
        <div class="panel-status-row" id="panelStatusRow"></div>
        <div class="panel-route" id="panelRoute"></div>
        <div class="panel-progress-wrap" id="panelProgress"></div>
        <div class="panel-section-title">Salida</div>
        <div class="panel-times" id="panelDep"></div>
        <div class="panel-section-title">Llegada</div>
        <div class="panel-times" id="panelArr"></div>
        <div class="panel-section-title">Información</div>
        <div id="panelInfo"></div>
    </div>
</div>

<script>
window.c=['#4361ee','#3a0ca3','#7209b7','#f72585','#4cc9f0','#22c55e','#f59e0b','#ef4444'];let o=10,l=false,p=new Map();const m={'En Route':'en-route','Taxi Out':'en-route','Taxi In':'en-route','Arrived':'arrived','Scheduled':'scheduled'};function fmt(t){if(!t)return'—';const d=new Date(t);return d.toLocaleString([],{day:'2-digit',month:'2-digit',year:'numeric',hour:'2-digit',minute:'2-digit'});}function getLogo(a,e){return`<img loading="lazy" src="/images/airlines/${a}.png" alt="${a}" onerror="try{if(!this.dataset.step){this.dataset.step='1';this.src='https://e1.flightcdn.com/images/airline_logos/90p/${a.slice(0,3)}.png';}else if(this.dataset.step==='1'){this.dataset.step='2';this.src='https://content.airhex.com/content/logos/airlines_${e}_100_100_s.png';}else if(this.dataset.step==='2'){this.dataset.step='3';this.src='https://pics.avs.io/ab_icons/150/${a}.png';}else{const l='${a.charAt(0)}';const b=window.c[l.charCodeAt(0)%8];this.parentElement.innerHTML='<div style=\"width:32px;height:32px;border-radius:8px;background:'+b+';color:white;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:1rem;\">'+l+'</div>';}}catch(e){}">`;}function addRow(r){const st=m[Object.keys(m).find(k=>r.s.includes(k))||'']||'';const a=r.oi||r.oia?.slice(0,3)?.toUpperCase()||'';return`<tr onclick="abrirPanel(${JSON.stringify(r.rw).replace(/"/g,'&quot;')},'${r.v}')"><td><div class="airline-logo">${getLogo(a,r.oia)}</div><td><span class="flight-num">${r.v}</span><td><div class="route">${r.o}<span class="route-arrow">→</span>${r.d}</div><td><span class="date">${r.hs||'Indeterminada'}</span><td><span class="status ${st}">${r.s}</span><td><span class="date">${r.fb}</span>`;}function loadMore(){if(l||p.has(o))return;l=true;const id=document.getElementById('loading-indicator');id.style.display='block';const req=fetch(`/api/historial?offset=${o}&limit=20`).then(r=>r.json()).then(t=>{if(t.r?.length){const tb=document.getElementById('flightsTableBody');t.r.forEach(r=>{tb.insertAdjacentHTML('beforeend',addRow(r))});o+=t.r.length;p.set(o,'loaded');}l=false;id.style.display='none';}).catch(()=>{l=false;id.style.display='none';});p.set(o,req);}document.addEventListener('DOMContentLoaded',()=>{document.querySelectorAll('.tz-datetime').forEach(r=>{if(r.dataset.time){const d=new Date(r.dataset.time);r.innerText=d.toLocaleString([],{day:'2-digit',month:'2-digit',year:'numeric',hour:'2-digit',minute:'2-digit'});}});const trig=document.getElementById('infinite-scroll-trigger');if(trig){let ti;new IntersectionObserver(e=>{if(e[0].isIntersecting&&!l){clearTimeout(ti);ti=setTimeout(loadMore,100);}},,{threshold:.1}).observe(trig);}});function abrirPanel(d,fn){const icao=d.operator_icao||d.operator||fn.slice(0,3).toUpperCase();const iata=d.operator_iata||fn.slice(0,2).toUpperCase();document.getElementById('panelLogo').innerHTML=`${getLogo(icao,iata)}`;document.getElementById('panelFlightNum').textContent=fn;document.getElementById('panelOperator').textContent=d.operator_icao||d.operator||'';const st=d.status||'—';const sc=m[Object.keys(m).find(k=>st.includes(k))||'']||'';document.getElementById('panelStatusRow').innerHTML=`<span class="status ${sc}">${st}</span>`;const orig=d.origin||{};const dest=d.destination||{};document.getElementById('panelRoute').innerHTML=`<div class="panel-ep"><div class="panel-ep-code">${orig.code_iata||orig.code||'—'}</div><div class="panel-ep-name">${orig.city||orig.name||''}</div></div><div class="panel-route-line"></div><div class="panel-ep" style="text-align:right"><div class="panel-ep-code">${dest.code_iata||dest.code||'—'}</div><div class="panel-ep-name">${dest.city||dest.name||''}</div></div>`;const pct=d.progress_percent||0;document.getElementById('panelProgress').innerHTML=pct>0?`<div class="panel-progress-bar"><div class="panel-progress-fill" style="width:${pct}%"></div></div><div class="panel-progress-label"><span>${orig.code_iata||'—'}</span><span>${pct}%</span><span>${dest.code_iata||'—'}</span></div>`:'';document.getElementById('panelDep').innerHTML=`<div class="panel-time-item"><div class="panel-time-label">Programada</div><div class="panel-time-val">${fmt(d.scheduled_out)}</div></div><div class="panel-time-item"><div class="panel-time-label">Estimada</div><div class="panel-time-val">${fmt(d.estimated_out)}</div></div><div class="panel-time-item"><div class="panel-time-label">Real</div><div class="panel-time-val ${(d.actual_out&&d.scheduled_out&&new Date(d.actual_out)>new Date(d.scheduled_out))?'delayed':d.actual_out?'ontime':''}">${fmt(d.actual_out)}</div></div>`;document.getElementById('panelArr').innerHTML=`<div class="panel-time-item"><div class="panel-time-label">Programada</div><div class="panel-time-val">${fmt(d.scheduled_in)}</div></div><div class="panel-time-item"><div class="panel-time-label">Estimada</div><div class="panel-time-val">${fmt(d.estimated_in)}</div></div><div class="panel-time-item"><div class="panel-time-label">Real</div><div class="panel-time-val ${(d.actual_in&&d.scheduled_in&&new Date(d.actual_in)>new Date(d.scheduled_in))?'delayed':d.actual_in?'ontime':''}">${fmt(d.actual_in)}</div></div>`;let info='';if(d.aircraft_type)info+=`<div class="panel-info-row"><span class="panel-info-label">Aeronave</span><span class="panel-info-val">${d.aircraft_type}</span></div>`;if(d.registration)info+=`<div class="panel-info-row"><span class="panel-info-label">Matrícula</span><span class="panel-info-val">${d.registration}</span></div>`;if(d.operator_icao)info+=`<div class="panel-info-row"><span class="panel-info-label">Aerolínea ICAO</span><span class="panel-info-val">${d.operator_icao}</span></div>`;if(d.operator_iata)info+=`<div class="panel-info-row"><span class="panel-info-label">Aerolínea IATA</span><span class="panel-info-val">${d.operator_iata}</span></div>`;if(orig.name)info+=`<div class="panel-info-row"><span class="panel-info-label">Origen</span><span class="panel-info-val">${orig.name}</span></div>`;if(dest.name)info+=`<div class="panel-info-row"><span class="panel-info-label">Destino</span><span class="panel-info-val">${dest.name}</span></div>`;if(d.last_position){info+=`<div class="panel-info-row"><span class="panel-info-label">Velocidad</span><span class="panel-info-val">${d.last_position.groundspeed} kt</span></div>`;info+=`<div class="panel-info-row"><span class="panel-info-label">Altitud</span><span class="panel-info-val">${d.last_position.altitude*100} ft</span></div>`;}document.getElementById('panelInfo').innerHTML=info;document.getElementById('panelOverlay').classList.add('open');document.getElementById('detailPanel').classList.add('open');}function cerrarPanel(){document.getElementById('panelOverlay').classList.remove('open');document.getElementById('detailPanel').classList.remove('open');}document.addEventListener('keydown',e=>{if(e.key==='Escape')cerrarPanel();});if('serviceWorker'in navigator){navigator.serviceWorker.register('/sw.js').catch(()=>{});}
</script>
{% endblock %}
