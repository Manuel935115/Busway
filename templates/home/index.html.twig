{% extends 'base.html.twig' %}

{% block title %}Busway — Inicio{% endblock %}

{% block body %}
<div class="text-center" style="max-width: 600px; margin: 3rem auto;">
    <article>
        <img src="{{ app.request.getBasePath() }}/images/logo_original-removebg-preview.png" alt="Busway Logo" style="height: 80px; margin-bottom: 1rem;">

        <h1>{{ mensaje }}</h1>

        <p style="margin: 1rem 0;">
            Has configurado correctamente tu controlador <code>{{ controller_name }}</code>.
        </p>

        <div class="alert alert-success mt-2">
            ✓ Sistema listo para rastrear vuelos, trenes y buses en tiempo real.
        </div>

        <div style="margin-top: 1.5rem;">
            <a href="https://symfony.com/doc/6.4/index.html" target="_blank" rel="noopener noreferrer" class="button">
                Ver documentación →
            </a>
        </div>

        <small class="mt-3" style="display: block; color: #666;">
            Generado el: {{ fecha|date('d/m/Y H:i') }}
        </small>
    </article>
</div>
{% endblock %}