{% extends 'base.html.twig' %}

{% block title %}Busway — Configuración correcta{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap');

        :root {
            --primary: #4361ee;
            --primary-2: #22c55e;
            --shadow: 0 22px 55px rgba(2, 6, 23, 0.10);
        }

        body.dark-mode {
            --shadow: 0 22px 55px rgba(0, 0, 0, 0.4);
        }

        * { box-sizing: border-box; }

        body {
            margin: 0;
            min-height: 100vh;
            padding: 24px;
            display: grid;
            place-items: center;
            background: var(--main-bg);
            color: var(--text-primary);
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            -webkit-font-smoothing: antialiased;
            -moz-osx-font-smoothing: grayscale;
            transition: background 0.3s, color 0.3s;
        }

        body:not(.dark-mode) {
            background: radial-gradient(1200px circle at top right, #e0e7ff 0%, #eff6ff 26%, #f8fafc 55%, #f3f4f6 100%);
        }

        .welcome-card {
            width: 100%;
            max-width: 560px;
            background: var(--card-bg);
            border: 1px solid var(--border);
            border-radius: 22px;
            box-shadow: var(--shadow);
            backdrop-filter: blur(14px);
            padding: 30px 28px 26px;
            position: relative;
            overflow: hidden;
            text-align: center;
            animation: riseIn 650ms cubic-bezier(0.2, 0.8, 0.2, 1) both;
            transition: background 0.3s, border 0.3s;
        }

        .welcome-card::before,
        .welcome-card::after {
            content: '';
            position: absolute;
            left: 0;
            top: 0;
            z-index: 0;
            pointer-events: none;
        }

        .welcome-card::before {
            right: 0;
            bottom: 0;
            background: linear-gradient(135deg,
                rgba(67, 97, 238, 0.35) 0%,
                rgba(34, 197, 94, 0.22) 52%,
                rgba(67, 97, 238, 0) 76%
            );
        }

        .welcome-card::after {
            height: 6px;
            background: linear-gradient(90deg, var(--primary), var(--primary-2));
        }

        .welcome-card > * {
            position: relative;
            z-index: 1;
        }

        .card-top {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
            margin-bottom: 10px;
        }

        .brand-logo {
            height: 34px;
            width: auto;
            opacity: 0.95;
        }

        .card-pill {
            font-size: 0.75rem;
            font-weight: 800;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            color: var(--text-primary);
            background: rgba(var(--accent), 0.1);
            border: 1px solid var(--border);
            padding: 8px 12px;
            border-radius: 999px;
            white-space: nowrap;
        }
        body.dark-mode .card-pill {
            background: rgba(255, 255, 255, 0.05);
        }

        .welcome-card h1 {
            margin: 10px 0 12px;
            font-size: 1.95rem;
            line-height: 1.2;
            letter-spacing: -0.02em;
        }

        .welcome-card p {
            margin: 0;
            color: var(--text-muted);
            line-height: 1.65;
        }

        .welcome-card code {
            background: rgba(67, 97, 238, 0.08);
            border: 1px solid rgba(67, 97, 238, 0.18);
            color: var(--accent);
            padding: 0.18em 0.5em;
            border-radius: 10px;
            font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, 'Liberation Mono', 'Courier New', monospace;
            font-size: 0.95em;
            white-space: nowrap;
        }
        body.dark-mode .welcome-card code {
            background: rgba(255, 255, 255, 0.05);
            color: #818cf8;
        }

        .actions {
            margin-top: 18px;
        }

        .btn-doc {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            padding: 12px 18px;
            background: linear-gradient(180deg, rgba(67, 97, 238, 1) 0%, rgba(67, 97, 238, 0.95) 100%);
            color: #fff;
            text-decoration: none;
            border-radius: 14px;
            font-weight: 800;
            font-size: 0.95rem;
            box-shadow: 0 14px 28px rgba(67, 97, 238, 0.25);
            border: 1px solid rgba(255, 255, 255, 0.18);
            transition: transform 180ms ease, box-shadow 180ms ease, filter 180ms ease;
            user-select: none;
        }

        .btn-doc:hover {
            transform: translateY(-2px) scale(1.05);
            box-shadow: 0 18px 40px rgba(67, 97, 238, 0.30), 0 0 16px rgba(67, 97, 238, 0.4);
            filter: saturate(1.05);
        }

        .btn-doc:active {
            transform: translateY(-1px);
        }

        .btn-doc:focus-visible {
            outline: 3px solid rgba(67, 97, 238, 0.35);
            outline-offset: 3px;
        }

        .btn-doc svg {
            width: 18px;
            height: 18px;
        }

        .meta-info {
            margin-top: 18px;
            padding-top: 16px;
            border-top: 1px solid var(--border);
            color: var(--text-muted);
            font-size: 0.92rem;
        }

        @keyframes riseIn {
            from { opacity: 0; transform: translateY(14px) scale(0.99); }
            to { opacity: 1; transform: translateY(0) scale(1); }
        }

        @media (max-width: 420px) {
            body { padding: 16px; }
            .welcome-card { padding: 26px 18px 20px; }
            .card-top { flex-direction: column; align-items: flex-start; }
            .card-pill { width: 100%; text-align: left; }
            .welcome-card code { white-space: normal; }
        }

        @media (prefers-reduced-motion: reduce) {
            .welcome-card { animation: none; }
            .btn-doc { transition: none; }
        }
    </style>
{% endblock %}

{% block body %}
<div class="welcome-card">
    <div class="card-top">
        <img
            src="{{ app.request.getBasePath() }}/images/logo_original-removebg-preview.png"
            class="brand-logo"
            alt="Busway Logo"
        >
        <div class="card-pill">Configuración OK</div>
    </div>

    <h1>{{ mensaje }}</h1>

    <p>
        Has configurado correctamente tu controlador <code><strong>{{ controller_name }}</strong></code>.
    </p>

    <div class="actions">
        <a
            href="https://symfony.com/doc/6.4/index.html"
            target="_blank"
            rel="noopener noreferrer"
            class="btn-doc"
        >
            Ver documentación
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M18 13v6a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V9a2 2 0 0 1 2-2h6"></path>
                <polyline points="15 3 21 3 21 9"></polyline>
                <line x1="10" y1="14" x2="21" y2="3"></line>
            </svg>
        </a>
    </div>

    <div class="meta-info">
        Generado el: {{ fecha|date('d/m/Y H:i') }}
    </div>
</div>
{% endblock %}